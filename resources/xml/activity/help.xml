<!--
    帮助页面布局
    左侧 RecyclingGrid（单列标题列表） + 右侧说明内容
-->

<MyFrame id="help/frame">
    <brls:Box
        id="help/content"
        width="100%"
        height="100%"
        axis="row"
        title="@i18n/help/pageTitle">

        <!-- 左侧：帮助条目列表 -->
        <RecyclingGrid
            id="help/grid"
            width="25%"
            height="100%"
            spanCount="1"
            itemHeight="70"
            itemSpace="18"/>

        <!-- 右侧：说明内容卡片 -->
        <brls:Box
            id="help/detail"
            width="auto"
            height="auto"
            grow="1"
            axis="column"
            focusable="true"
            marginTop="25"
            marginBottom="25"
            marginLeft="0"
            marginRight="40"
            paddingTop="40"
            paddingBottom="40"
            paddingLeft="40"
            paddingRight="40"
            backgroundColor="@theme/app/cardBg"
            cornerRadius="8"
            highlightCornerRadius="8"
            shadowType="generic">

            <!-- 内容区（动态填充） -->
            <brls:ScrollingFrame
                id="help/scroll"
                width="100%"
                grow="1">

                <brls:Box
                    id="help/container"
                    width="100%"
                    height="auto"
                    axis="column"/>

            </brls:ScrollingFrame>

        </brls:Box>

    </brls:Box>
</MyFrame>
