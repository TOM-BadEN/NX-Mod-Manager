<!--
    主页面布局文件
-->

<MyFrame id="home/frame">
    <brls:Box id="home/content" width="100%" height="100%" title="@i18n/home/pageTitle">
        <RecyclingGrid
            id="home/grid"
            width="auto"
            height="auto"
            grow="1"
            marginRight="7"
            marginTop="4"
            marginBottom="5"
            spanCount="3"
            itemHeight="160"
            itemSpace="18"/>
        <brls:Label
            id="home/noModHint"
            width="100%"
            height="100%"
            visibility="gone"
            focusable="true"
            hideHighlight="true"
            fontSize="32"
            text="@i18n/home/noModHint"
            textColor="@theme/app/textSecondary"
            horizontalAlign="center"
            verticalAlign="center"/>
    </brls:Box>
</MyFrame>
