<!--
    ImageViewer - 图片浏览组件布局
    全屏暗色遮罩 + 居中大图 + 底部页面指示器
-->

<brls:Box
    axis="column"
    justifyContent="center"
    alignItems="center"
    width="100%"
    height="100%">

    <!-- 当前图片 -->
    <brls:Image
        id="imageViewer/image"
        scalingType="fit"
        width="75%"
        height="75%"
        cornerRadius="15"
        shadowType="generic"
        focusable="true"
        hideHighlight="true"/>

    <!-- 过渡图片（绝对定位叠放，初始不可见） -->
    <brls:Image
        id="imageViewer/imageNext"
        scalingType="fit"
        width="75%"
        height="75%"
        cornerRadius="15"
        shadowType="generic"
        positionType="absolute"
        visibility="invisible"/>

    <!-- 指示器容器（绝对定位，底部居中，默认隐藏） -->
    <brls:Box
        id="imageViewer/indicator"
        axis="row"
        justifyContent="center"
        alignItems="center"
        positionType="absolute"
        positionBottom="40"
        positionLeft="0"
        positionRight="0"
        visibility="gone"/>

</brls:Box>
