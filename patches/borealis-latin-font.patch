 #ifdef __SWITCH__
-    static int regular = Application::getFont(FONT_CHINESE_SIMPLIFIED);
+    // CJK locales use the Chinese font as primary (it carries the CJK glyphs);
+    // Latin locales must use the Standard font as primary so accented Latin
+    // characters (e.g. Portuguese á ã ç é í õ) render with proper Latin glyphs
+    // instead of the CJK font's wider look-alikes. Both fonts have a full
+    // fallback chain (see SwitchFontLoader::loadFonts) so mixed content works.
+    static int def = [] {
+        std::string locale = Application::getLocale();
+        bool cjk = locale == LOCALE_ZH_HANS || locale == LOCALE_ZH_HANT
+            || locale == LOCALE_ZH_CN || locale == LOCALE_ZH_TW
+            || locale == LOCALE_JA || locale == LOCALE_Ko;
+        int primary = Application::getFont(cjk ? FONT_CHINESE_SIMPLIFIED : FONT_REGULAR);
+        if (primary == FONT_INVALID)
+            primary = Application::getFont(FONT_CHINESE_SIMPLIFIED);
+        return primary;
+    }();
+    return def;
 #else
     static int regular = Application::getFont(FONT_REGULAR);
-#endif
     return regular;
+#endif
 }
 
